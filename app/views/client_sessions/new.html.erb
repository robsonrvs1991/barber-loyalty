<div class="row justify-content-center mt-5">
  <div class="col-md-5">
    <div class="card shadow-sm">
      <div class="card-body p-4">
        <h1 class="h4 mb-3 text-center">Área do Cliente</h1>
        <p class="text-muted text-center">Acesse seu cartão fidelidade digital.</p>

        <%= form_with url: client_login_path, method: :post do |f| %>
          <div class="mb-3">
            <%= f.label :email, "E-mail", class: "form-label" %>
            <%= f.email_field :email, class: "form-control", required: true %>
          </div>

          <div class="mb-3">
            <%= f.label :password, "Senha", class: "form-label" %>
            <%= f.password_field :password, class: "form-control", required: true %>
          </div>

          <%= f.submit "Entrar", class: "btn btn-primary w-100" %>
        <% end %>
      </div>
    </div>
  </div>
</div>
