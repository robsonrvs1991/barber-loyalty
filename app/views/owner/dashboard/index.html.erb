<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h3 mb-1">Painel Loy</h1>
    <p class="text-muted mb-0">Controle de empresas, acessos e assinaturas.</p>
  </div>

  <%= link_to "Nova empresa", new_owner_company_path, class: "btn btn-primary" %>
</div>

<div class="row mb-4">
  <div class="col-md-3 mb-3"><div class="card shadow-sm"><div class="card-body"><div class="text-muted">Empresas</div><div class="h2 mb-0"><%= @companies_count %></div></div></div></div>
  <div class="col-md-3 mb-3"><div class="card shadow-sm"><div class="card-body"><div class="text-muted">Ativas</div><div class="h2 mb-0"><%= @active_subscriptions_count %></div></div></div></div>
  <div class="col-md-3 mb-3"><div class="card shadow-sm"><div class="card-body"><div class="text-muted">Bloqueadas</div><div class="h2 mb-0"><%= @blocked_subscriptions_count %></div></div></div></div>
  <div class="col-md-3 mb-3"><div class="card shadow-sm"><div class="card-body"><div class="text-muted">Free</div><div class="h2 mb-0"><%= @free_subscriptions_count %></div></div></div></div>
</div>

<div class="card shadow-sm">
  <div class="card-body">
    <h2 class="h5 mb-3">Últimas empresas</h2>

    <table class="table align-middle">
      <thead>
        <tr>
          <th>Empresa</th>
          <th>Responsável</th>
          <th>Status</th>
          <th>Plano</th>
          <th class="text-end"></th>
        </tr>
      </thead>
      <tbody>
        <% @companies.each do |company| %>
          <tr>
            <td><%= company.name %></td>
            <td><%= company.owner_user&.email || "-" %></td>
            <td><%= company.subscription&.status_label || "Sem assinatura" %></td>
            <td>R$ <%= number_with_precision(company.subscription&.price || 0, precision: 2) %></td>
            <td class="text-end"><%= link_to "Ver", owner_company_path(company), class: "btn btn-sm btn-outline-primary" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
