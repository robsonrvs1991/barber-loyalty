<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0">Empresas</h1>
  <%= link_to "Nova empresa", new_owner_company_path, class: "btn btn-primary" %>
</div>

<div class="card shadow-sm">
  <div class="card-body">
    <table class="table align-middle">
      <thead>
        <tr>
          <th>Empresa</th>
          <th>E-mail</th>
          <th>Responsável</th>
          <th>Status</th>
          <th>Free</th>
          <th>Bloqueada</th>
          <th class="text-end"></th>
        </tr>
      </thead>
      <tbody>
        <% @companies.each do |company| %>
          <tr>
            <td><%= company.name %></td>
            <td><%= company.email %></td>
            <td><%= company.owner_user&.email || "-" %></td>
            <td><%= company.subscription&.status_label || "Sem assinatura" %></td>
            <td><%= company.subscription&.free? ? "Sim" : "Não" %></td>
            <td><%= company.subscription&.blocked? ? "Sim" : "Não" %></td>
            <td class="text-end"><%= link_to "Ver", owner_company_path(company), class: "btn btn-sm btn-outline-primary" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
