<div class="card shadow-sm"><div class="card-body">
<%= form_with model: customer, url: customer.persisted? ? customer_path(customer) : customers_path do |f| %>
  <% if customer.errors.any? %><div class="alert alert-danger"><ul class="mb-0"><% customer.errors.full_messages.each do |message| %><li><%= message %></li><% end %></ul></div><% end %>
  <div class="mb-3"><%= f.label :name, "Nome", class: "form-label" %><%= f.text_field :name, class: "form-control", required: true %></div>
  <div class="mb-3"><%= f.label :email, "E-mail", class: "form-label" %><%= f.email_field :email, class: "form-control", required: true %></div>
  <div class="mb-3"><%= f.label :phone, "Telefone", class: "form-label" %><%= f.text_field :phone, class: "form-control" %></div>
  <div class="d-flex gap-2"><%= f.submit "Salvar", class: "btn btn-primary" %><%= link_to "Voltar", customers_path, class: "btn btn-outline-secondary" %></div>
<% end %>
</div></div>
