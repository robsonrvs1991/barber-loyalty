<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0">Clientes</h1>
  <%= link_to "Novo Cliente", new_customer_path, class: "btn btn-primary" %>
</div>

<div class="card shadow-sm">
  <div class="card-body">
    <table class="table table-hover align-middle">
      <thead><tr><th>Nome</th><th>E-mail</th><th>Telefone</th><th>Pontos</th><th></th></tr></thead>
      <tbody>
        <% @customers.each do |customer| %>
          <tr>
            <td><%= customer.name %></td>
            <td><%= customer.email %></td>
            <td><%= customer.phone %></td>
            <td><%= customer.loyalty_points.to_i %></td>
            <td class="text-end"><%= link_to "Ver", customer_path(customer), class: "btn btn-sm btn-outline-primary" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
