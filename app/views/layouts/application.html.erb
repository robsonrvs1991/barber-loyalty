<!DOCTYPE html>
<html>
  <head>
    <title>Fideli</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" rescue nil %>
    <%= javascript_importmap_tags rescue nil %>
  </head>

  <body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
      <div class="container">
        <%= link_to "Fideli", root_path, class: "navbar-brand fw-semibold" %>

        <% if logged_in? && barber? %>
          <div class="navbar-nav ms-auto">
            <%= link_to "Dashboard", root_path, class: "nav-link" %>
            <%= link_to "Clientes", customers_path, class: "nav-link" %>
            <%= link_to "Atendimentos", appointments_path, class: "nav-link" %>
            <%= link_to "Serviços", services_path, class: "nav-link" %>
            <%= link_to "Fidelidade", loyalty_program_path, class: "nav-link" %>
            <%= link_to "Recompensas", rewards_path, class: "nav-link" %>
            <%= button_to "Sair", logout_path, method: :delete, class: "btn btn-sm btn-outline-light ms-lg-3" %>
          </div>
        <% elsif defined?(client_logged_in?) && client_logged_in? %>
          <div class="navbar-nav ms-auto">
            <span class="navbar-text text-white-50">Cartão fidelidade</span>
          </div>
        <% end %>
      </div>
    </nav>

    <main class="container">
      <% if notice.present? %>
        <div class="alert alert-success"><%= notice %></div>
      <% end %>

      <% if alert.present? %>
        <div class="alert alert-danger"><%= alert %></div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
