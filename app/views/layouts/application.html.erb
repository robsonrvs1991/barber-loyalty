<!DOCTYPE html>
<html>
  <head>
    <title>Loy</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" rescue nil %>
    <%= javascript_importmap_tags rescue nil %>
  </head>

  <body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
      <div class="container">
        <% if controller_path.start_with?("owner") %>
          <%= link_to "Loy", owner_dashboard_path, class: "navbar-brand fw-semibold" %>

          <div class="navbar-nav ms-auto">
            <%= link_to "Dashboard", owner_dashboard_path, class: "nav-link" %>
            <%= link_to "Empresas", owner_companies_path, class: "nav-link" %>
            <%= button_to "Sair", logout_path, method: :delete, class: "btn btn-sm btn-outline-light ms-lg-3" %>
          </div>
        <% elsif controller_name.start_with?("client") || request.path.start_with?("/cliente") %>
          <%= link_to "Loy", client_portal_path, class: "navbar-brand fw-semibold" %>

          <div class="navbar-nav ms-auto">
            <span class="navbar-text text-white-50 me-3">Meu cartão fidelidade</span>
            <%= button_to "Sair", client_logout_path, method: :delete, class: "btn btn-sm btn-outline-light" %>
          </div>
        <% elsif logged_in? && business? %>
          <%= link_to "Loy", root_path, class: "navbar-brand fw-semibold" %>

          <div class="navbar-nav ms-auto">
            <%= link_to "Dashboard", root_path, class: "nav-link" %>
            <%= link_to "Clientes", customers_path, class: "nav-link" %>
            <%= link_to "Atendimentos", appointments_path, class: "nav-link" %>
            <%= link_to "Serviços", services_path, class: "nav-link" %>
            <%= link_to "Fidelidade", loyalty_program_path, class: "nav-link" %>
            <%= link_to "Recompensas", rewards_path, class: "nav-link" %>
            <%= button_to "Sair", logout_path, method: :delete, class: "btn btn-sm btn-outline-light ms-lg-3" %>
          </div>
        <% else %>
          <%= link_to "Loy", root_path, class: "navbar-brand fw-semibold" %>
        <% end %>
      </div>
    </nav>

    <main class="container">
      <% if notice.present? %>
        <div class="alert alert-success"><%= notice %></div>
      <% end %>

      <% if alert.present? %>
        <div class="alert alert-danger"><%= alert %></div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
