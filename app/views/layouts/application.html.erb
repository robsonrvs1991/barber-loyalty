<!DOCTYPE html>
<html>
  <head>
    <title>Fideli</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
      <div class="container">
        <%= link_to "Fideli", root_path, class: "navbar-brand" %>
        <div class="navbar-nav ms-auto">
          <% if logged_in? %>
            <% if barber? %>
              <%= link_to "Dashboard", root_path, class: "nav-link" %>
              <%= link_to "Clientes", customers_path, class: "nav-link" %>
              <%= link_to "Atendimentos", appointments_path, class: "nav-link" %>
              <%= link_to "Serviços", services_path, class: "nav-link" %>
              <%= link_to "Fidelidade", loyalty_program_path, class: "nav-link" %>
              <%= link_to "Recompensas", rewards_path, class: "nav-link" %>
            <% end %>
            <%= button_to "Sair", logout_path, method: :delete, class: "btn btn-outline-light btn-sm ms-2" %>
          <% end %>
        </div>
      </div>
    </nav>

    <main class="container">
      <% if notice %><div class="alert alert-success"><%= notice %></div><% end %>
      <% if alert %><div class="alert alert-danger"><%= alert %></div><% end %>
      <%= yield %>
    </main>
  </body>
</html>
