<div class="row justify-content-center align-items-center g-4 py-4 py-lg-5">
  <div class="col-lg-6">
    <div class="pe-lg-5">
      <span class="badge text-bg-primary rounded-pill px-3 py-2 mb-3">
        Plataforma de fidelidade
      </span>

      <h1 class="display-5 fw-bold mb-3">
        Acesse sua conta Loy
      </h1>

      <p class="lead text-muted mb-4">
        Gerencie clientes, itens, atendimentos, pontos e recompensas em uma plataforma simples para qualquer tipo de negócio.
      </p>

      <div class="row g-3">
        <div class="col-sm-6">
          <div class="card border-0 shadow-sm h-100 rounded-4">
            <div class="card-body">
              <div class="fs-2 mb-2">🎯</div>
              <h6 class="fw-bold mb-1">Fidelidade simples</h6>
              <p class="text-muted small mb-0">
                Crie programas por pontos, visitas, produtos ou serviços.
              </p>
            </div>
          </div>
        </div>

        <div class="col-sm-6">
          <div class="card border-0 shadow-sm h-100 rounded-4">
            <div class="card-body">
              <div class="fs-2 mb-2">🎁</div>
              <h6 class="fw-bold mb-1">Recompensas controladas</h6>
              <p class="text-muted small mb-0">
                Gere, acompanhe e resgate recompensas com segurança.
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-4 d-flex flex-wrap gap-2">
        <%= link_to "Criar conta da empresa", signup_path, class: "btn btn-outline-primary" %>
        <%= link_to "Portal do cliente", client_login_path, class: "btn btn-outline-secondary" %>
      </div>
    </div>
  </div>

  <div class="col-lg-5">
    <div class="card border-0 shadow-lg rounded-4">
      <div class="card-body p-4 p-lg-5">
        <div class="text-center mb-4">
          <div class="d-inline-flex align-items-center justify-content-center bg-white border rounded-4 shadow-sm p-2 mb-3">
            <%= image_tag "logo.png", height: 52 %>
          </div>

          <h2 class="h3 fw-bold mb-1">Entrar</h2>
          <p class="text-muted mb-0">Informe seus dados para continuar.</p>
        </div>

        <%= form_with url: login_path, local: true do |form| %>
          <div class="mb-3">
            <%= form.label :email, "E-mail", class: "form-label fw-semibold" %>
            <%= form.email_field :email,
              class: "form-control form-control-lg",
              placeholder: "seuemail@empresa.com",
              autofocus: true,
              autocomplete: "email" %>
          </div>

          <div class="mb-4">
            <%= form.label :password, "Senha", class: "form-label fw-semibold" %>
            <%= form.password_field :password,
              class: "form-control form-control-lg",
              placeholder: "Digite sua senha",
              autocomplete: "current-password" %>
          </div>

          <%= form.submit "Acessar minha conta", class: "btn btn-primary btn-lg w-100 shadow-sm" %>
        <% end %>

        <div class="text-center mt-4">
          <p class="text-muted small mb-2">Ainda não usa o Loy?</p>
          <%= link_to "Cadastre sua empresa", signup_path, class: "fw-semibold text-decoration-none" %>
        </div>
      </div>
    </div>

    <p class="text-center text-muted small mt-3 mb-0">
      Acesso exclusivo para empresas e administradores.
    </p>
  </div>
</div>