<div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
  <div>
    <div class="d-flex align-items-center gap-2 mb-2">
      <span class="badge text-bg-primary rounded-pill px-3 py-2">Catálogo</span>
      <span class="text-muted small">Itens, produtos e serviços do negócio</span>
    </div>

    <h1 class="fw-bold mb-1">Itens/Serviços</h1>
    <p class="text-muted mb-0">
      Cadastre tudo que pode gerar pontos: produtos, serviços, atendimentos ou itens vendidos.
    </p>
  </div>

  <div>
    <%= link_to new_service_path, class: "btn btn-primary btn-lg shadow-sm" do %>
      + Novo item/serviço
    <% end %>
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-md-4">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <p class="text-muted mb-1">Total cadastrados</p>
        <h2 class="fw-bold mb-0"><%= @total_services %></h2>
      </div>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <p class="text-muted mb-1">Ativos</p>
        <h2 class="fw-bold text-success mb-0"><%= @active_services %></h2>
      </div>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <p class="text-muted mb-1">Inativos</p>
        <h2 class="fw-bold text-secondary mb-0"><%= @inactive_services %></h2>
      </div>
    </div>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <% if @services.any? %>
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th class="ps-4">Nome</th>
              <th>Valor</th>
              <th>Pontos</th>
              <th>Status</th>
              <th class="text-end pe-4">Ações</th>
            </tr>
          </thead>

          <tbody>
            <% @services.each do |service| %>
              <tr>
                <td class="ps-4">
                  <strong><%= service.name %></strong>
                </td>

                <td>
                  <%= number_to_currency(service.price || 0, unit: "R$ ", separator: ",", delimiter: ".") %>
                </td>

                <td>
                  <span class="badge text-bg-primary rounded-pill">
                    <%= service.points %> ponto(s)
                  </span>
                </td>

                <td>
                  <% if service.active? %>
                    <span class="badge text-bg-success">Ativo</span>
                  <% else %>
                    <span class="badge text-bg-secondary">Inativo</span>
                  <% end %>
                </td>

                <td class="text-end pe-4">
                  <div class="btn-group">
                    <%= link_to "Ver", service_path(service), class: "btn btn-sm btn-outline-primary" %>
                    <%= link_to "Editar", edit_service_path(service), class: "btn btn-sm btn-outline-secondary" %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center p-5">
        <h2 class="h4 fw-bold mb-2">Nenhum item/serviço cadastrado</h2>
        <p class="text-muted mb-4">
          Cadastre produtos, serviços ou atendimentos para começar a pontuar seus clientes.
        </p>

        <%= link_to "Cadastrar primeiro item/serviço", new_service_path, class: "btn btn-primary btn-lg" %>
      </div>
    <% end %>
  </div>
</div>