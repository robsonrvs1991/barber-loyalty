<%= form_with model: @service do |form| %>
  <% if @service.errors.any? %>
    <div class="alert alert-danger border-0 shadow-sm">
      <strong>Revise os campos abaixo:</strong>
      <ul class="mb-0 mt-2">
        <% @service.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-4">
    <%= form.label :name, "Nome do item/serviço", class: "form-label fw-semibold" %>
    <%= form.text_field :name,
      class: "form-control form-control-lg",
      placeholder: "Ex: Café, Pizza, Corte, Consulta, Produto X" %>
    <div class="form-text">
      Use um nome claro para identificar o que o cliente comprou, consumiu ou realizou.
    </div>
  </div>

  <div class="row">
    <div class="col-md-6 mb-4">
      <%= form.label :price, "Valor (R$)", class: "form-label fw-semibold" %>
      <%= form.number_field :price,
        class: "form-control form-control-lg",
        min: 0,
        step: 0.01,
        placeholder: "0,00" %>

      <div class="form-text">
        Valor padrão do item ou serviço.
      </div>
    </div>

    <div class="col-md-6 mb-4">
      <%= form.label :points, "Pontos gerados", class: "form-label fw-semibold" %>
      <%= form.number_field :points,
        class: "form-control form-control-lg",
        min: 0,
        step: 1,
        placeholder: "1" %>

      <div class="form-text">
        Quantidade de pontos gerados para este item/serviço.
      </div>
    </div>
  </div>

  <div class="card border-0 bg-light mb-4">
    <div class="card-body">
      <div class="form-check form-switch">
        <%= form.check_box :active, class: "form-check-input", role: "switch" %>
        <%= form.label :active, "Item/serviço ativo", class: "form-check-label fw-semibold" %>
      </div>

      <small class="text-muted">
        Itens inativos ficam preservados no histórico, mas deixam de aparecer em novos atendimentos.
      </small>
    </div>
  </div>

  <div class="d-flex justify-content-end gap-2">
    <%= link_to "Cancelar", services_path, class: "btn btn-outline-secondary btn-lg" %>
    <%= form.submit "Salvar item/serviço", class: "btn btn-primary btn-lg" %>
  </div>
<% end %>